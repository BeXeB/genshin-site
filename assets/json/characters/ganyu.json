{
    "constellation": {
        "c1": {
            "descriptionRaw": "Charge Level 2 Frostflake Arrows or Frostflake Arrow Blooms decrease opponents' <color=#99FFFFFF>Cryo RES</color> by 15% for 6s upon hit.\nA hit also regenerates 2 Energy for Ganyu. This effect can only occur once per Charge Level 2 Frostflake Arrow, regardless if Frostflake Arrow itself or its Bloom hits the target.",
            "name": "Dew-Drinker"
        },
        "c2": {
            "descriptionRaw": "<color=#FFD780FF>Trail of the Qilin</color> gains 1 additional charge.",
            "name": "The Auspicious"
        },
        "c3": {
            "descriptionRaw": "Increases the Level of <color=#FFD780FF>Celestial Shower</color> by 3.\nMaximum upgrade level is 15.",
            "name": "Cloud-Strider"
        },
        "c4": {
            "descriptionRaw": "Opponents standing within the AoE of <color=#FFD780FF>Celestial Shower</color> take increased DMG. This effect strengthens over time.\nIncreased DMG taken begins at 5% and increases by 5% every 3s, up to a maximum of 25%.\nThe effect lingers for 3s after the opponent leaves the AoE.",
            "name": "Westward Sojourn"
        },
        "c5": {
            "descriptionRaw": "Increases the Level of <color=#FFD780FF>Trail of the Qilin</color> by 3.\nMaximum upgrade level is 15.",
            "name": "The Merciful"
        },
        "c6": {
            "descriptionRaw": "Using <color=#FFD780FF>Trail of the Qilin</color> causes the next Frostflake Arrow shot within 30s to not require charging.",
            "name": "The Clement"
        },
