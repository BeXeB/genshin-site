        },
        "c5": {
            "descriptionRaw": "Increases the Level of <color=#FFD780FF>Kamisato Art: Hyouka</color> by 3.\nMaximum upgrade level is 15.",
            "name": "Blossom Cloud Irutsuki"
        },
        "c6": {
            "descriptionRaw": "Kamisato Ayaka gains Usurahi Butou every 10s, increasing her Charged Attack DMG by 298%. This buff will be cleared 0.5s after Ayaka's Charged ATK hits an opponent, after which the timer for this ability will restart.",
            "name": "Dance of Suigetsu"
        },
