{
    "constellation": {
        "c1": {
            "descriptionRaw": "When Kamisato Ayaka's Normal or Charged Attacks deal <color=#99FFFFFF>Cryo DMG</color> to opponents, it has a 50% chance of decreasing the CD of <color=#FFD780FF>Kamisato Art: Hyouka</color> by 0.3s. This effect can occur once every 0.1s.",
            "name": "Snowswept Sakura"
        },
        "c2": {
