        },
        "c3": {
            "descriptionRaw": "Increases the Level of <color=#FFD780FF>Kamisato Art: Soumetsu</color> by 3.\nMaximum upgrade level is 15.",
            "name": "Frostbloom Kamifubuki"
        },
        "c4": {
            "descriptionRaw": "Opponents damaged by <color=#FFD780FF>Kamisato Art: Soumetsu</color>'s Frostflake Seki no To will have their DEF decreased by 30% for 6s.",
