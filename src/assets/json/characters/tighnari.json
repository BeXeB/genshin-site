{
    "constellation": {
        "c1": {
            "descriptionRaw": "Tighnari's Charged Attack CRIT Rate is increased by 15%.",
            "name": "Beginnings Determined at the Roots"
        },
        "c2": {
            "descriptionRaw": "When there are opponents within the Vijnana-Khanda Field created by <color=#FFD780FF>Vijnana-Phala Mine</color>, Tighnari gains 20% <color=#99FF88FF>Dendro DMG Bonus</color>.\nThe effect will last up to 6s if the field's duration ends or if it no longer has opponents within it.",
            "name": "Origins Known From the Stem"
        },
        "c3": {
            "descriptionRaw": "Increases the Level of <color=#FFD780FF>Fashioner's Tanglevine Shaft</color> by 3.\nMaximum upgrade level is 15.",
            "name": "Fortunes Read Amongst the Branches"
        },
        "c4": {
            "descriptionRaw": "When <color=#FFD780FF>Fashioner's Tanglevine Shaft</color> is unleashed, all nearby party members gain 60 Elemental Mastery for 8s. If the Fashioner's Tanglevine Shaft triggers a Burning, Bloom, Lunar-Bloom, Quicken, or Spread reaction, their Elemental Mastery will be further increased by 60. This latter case will also refresh the buff state's duration.",
            "name": "Withering Glimpsed in the Leaves"
        },
        "c5": {
            "descriptionRaw": "Increases the Level of <color=#FFD780FF>Vijnana-Phala Mine</color> by 3.\nMaximum upgrade level is 15.",
            "name": "Comprehension Amidst the Flowers"
        },
        "c6": {
            "descriptionRaw": "<color=#FFD780FF>Wreath Arrow</color>'s charging time is decreased by 0.9s, and will produce 1 additional Clusterbloom Arrow upon hit. This arrow deals 150% of Tighnari's ATK as DMG.",
            "name": "Karma Adjudged From the Leaden Fruit"
        },
