{
    "constellation": {
        "c1": {
            "descriptionRaw": "The CRIT Rate of Kaeya's Normal and Charge Attacks against opponents affected by <color=#99FFFFFF>Cryo</color> is increased by 15%.",
            "name": "Excellent Blood"
        },
        "c2": {
            "descriptionRaw": "While <color=#FFD780FF>Glacial Waltz</color> is in effect, for each opponent defeated, its duration is increased by 2.5s, up to a maximum of 15s.",
            "name": "Never-Ending Performance"
        },
        "c3": {
            "descriptionRaw": "Increases the Level of <color=#FFD780FF>Frostgnaw</color> by 3.\nMaximum upgrade level is 15.",
            "name": "Dance of Frost"
        },
        "c4": {
            "descriptionRaw": "Triggers automatically when Kaeya's HP falls below 20%:\nCreates a shield that absorbs damage equal to 30% of Kaeya's Max HP. Lasts for 20s.\nThis shield absorbs <color=#99FFFFFF>Cryo DMG</color> with 250% efficiency.\nCan only occur once every 60s.",
            "name": "Frozen Kiss"
        },
        "c5": {
            "descriptionRaw": "Increases the Level of <color=#FFD780FF>Glacial Waltz</color> by 3.\nMaximum upgrade level is 15.",
            "name": "Frostbiting Embrace"
        },
        "c6": {
            "descriptionRaw": "<color=#FFD780FF>Glacial Waltz</color> will generate 1 additional icicle, and will regenerate 15 Energy when cast.",
            "name": "Glacial Whirlwind"
        },
