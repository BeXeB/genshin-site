        "passive1": {
            "descriptionRaw": "When DMG dealt by a Dendro Core (including DMG from Burgeon and Hyperbloom) hits Kaveh, Kaveh will regain HP equal to 300% of his Elemental Mastery. This effect can be triggered once every 0.5s.",
            "name": "An Architect's Undertaking"
        },
        "passive2": {
            "descriptionRaw": "During <color=#FFD780FF>Painted Dome</color>, after Kaveh's Normal, Charged, or Plunging Attacks hit opponents, his Elemental Mastery will increase by 25. This effect can be triggered once every 0.1s. Max 4 stacks.\nThis effect will be canceled when Painted Dome's effects end.",
            "name": "A Craftsman's Curious Conceptions"
        },
        "passive3": {
            "descriptionRaw": "When Kaveh crafts Landscape, Building, and Courtyard-type Furnishings, he has a 100% chance to refund a portion of the materials used.",
            "name": "The Art of Budgeting"
        }
