{
    "constellation": {
        "c1": {
            "descriptionRaw": "The Shield Absorption of the Curtain of Slumber generated by <color=#FFD780FF>Nights of Formal Focus</color> is increased by 20%.\nAdditionally, when unleashing Nights of Formal Focus, she will generate a shield for any nearby party members who are not being protected by a Curtain of Slumber. This shield will have 35% of the absorption of a Curtain of Slumber, will last for 12s, and will absorb <color=#99FFFFFF>Cryo DMG</color> with 250% effectiveness.",
            "name": "Fortress of Fantasy"
        },
        "c2": {
            "descriptionRaw": "When Shooting Stars from <color=#FFD780FF>Nights of Formal Focus</color> strike opponents, they will each restore 1 Energy to Layla. Each Shooting Star can restore Energy to her in this manner once.",
            "name": "Light's Remit"
        },
        "c3": {
            "descriptionRaw": "Increases the Level of <color=#FFD780FF>Nights of Formal Focus</color> by 3.\nMaximum upgrade level is 15.",
            "name": "Secrets of the Night"
        },
        "c4": {
            "descriptionRaw": "When <color=#FFD780FF>Nights of Formal Focus</color> starts to fire off Shooting Stars, it will grant all nearby party members the Dawn Star effect, causing their Normal and Charged Attack DMG to increase based on 5% of Layla's Max HP.\nDawn Star can last up to 3s and will be removed 0.05s after dealing Normal or Charged Attack DMG.",
            "name": "Starry Illumination"
        },
        "c5": {
            "descriptionRaw": "Increases the Level of <color=#FFD780FF>Dream of the Star-Stream Shaker</color> by 3.\nMaximum upgrade level is 15.",
            "name": "Stream of Consciousness"
        },
        "c6": {
            "descriptionRaw": "Shooting Stars from <color=#FFD780FF>Nights of Formal Focus</color> deal 40% increased DMG, and Starlight Slugs from <color=#FFD780FF>Dream of the Star-Stream Shaker</color> deal 40% increased DMG.\nAdditionally, the interval between the creation of Night Stars via Nights of Formal Focus is decreased by 20%.",
            "name": "Radiant Soulfire"
        },
